JWT_AUDIENCE=qoex.client
JWT_SECURITY_KEY=your_base64_encoded_256_bit_secret_key
JWT_ACCESS_TOKEN_EXPIRATION=60
JWT_REFRESH_TOKEN_EXPIRATION=7

CORS_ALLOWED_ORIGIN=http://localhost:5173